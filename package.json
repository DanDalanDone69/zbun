{
  "name": "@2ez4dan/zbun",
  "version": "0.1.5",
  "description": "The fastest structured logging library for Bun — zero dependencies, zero allocations, lock-free async I/O",
  "keywords": [
    "bun",
    "logger",
    "logging",
    "structured-logging",
    "json-logger",
    "zero-dependency",
    "async-logging",
    "high-performance"
  ],
  "author": "Danielle Bote <daniellebote@gmail.com>",
  "license": "MIT",
  "repository": "https://github.com/DanDalanDone69/zbun",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "bench": "bun run benchmarks/run.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --sourcemap=external && bun x tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist",
    "build:types": "bun x tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist",
    "lint": "biome check src/ tests/ benchmarks/",
    "lint:fix": "biome check --write src/ tests/ benchmarks/",
    "format": "biome format --write src/ tests/ benchmarks/",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "bun-types": "^1.3.10",
    "pino": "^10.3.1",
    "typescript": "^5.0.0",
    "winston": "^3.19.0"
  }
}
